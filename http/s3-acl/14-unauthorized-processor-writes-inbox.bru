meta {
  name: 14 Unauthorized — Processor Writes Inbox
  type: http
  seq: 14
}

post {
  url: {{s3BaseUrl}}/demo/probe/processor-writes-inbox?key={{testKey}}
  body: none
  auth: none
}

tests {
  test("SeaweedFS denies processor write access to inbox with 403", function() {
    expect(res.status).to.equal(403);
  });

  test("response body confirms the SeaweedFS status code", function() {
    expect(res.body).to.include("403");
  });
}
