meta {
  name: 9 Presign Folder-Path Image URL
  type: http
  seq: 9
}

get {
  url: {{s3BaseUrl}}/demo/presign?key={{folderKey}}
  body: none
  auth: none
}

params:query {
  key: {{folderKey}}
}

assert {
  res.status: eq 200
}

script:post-response {
  bru.setGlobalEnvVar("folderPresignedUrl", res.body.url);
  bru.setGlobalEnvVar("resolvedFolderKey", res.body.key);
}
