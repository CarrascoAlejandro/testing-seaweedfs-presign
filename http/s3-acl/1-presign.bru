meta {
  name: 1 Get Presigned URL
  type: http
  seq: 1
}

get {
  url: {{s3BaseUrl}}/demo/presign?key={{testKey}}
  body: none
  auth: none
}

params:query {
  key: {{testKey}}
}

assert {
  res.status: eq 200
}

script:post-response {
  bru.setGlobalEnvVar("presignedUrl", res.body.url);
  bru.setGlobalEnvVar("resolvedTestKey", res.body.key);
}
