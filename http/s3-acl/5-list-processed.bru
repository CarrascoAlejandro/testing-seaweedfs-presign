meta {
  name: 5 List Processed
  type: http
  seq: 5
}

get {
  url: {{s3BaseUrl}}/demo/processed
  body: none
  auth: none
}

headers {
}

assert {
  res.status: eq 200
}

tests {
  test("response is an array", function() {
    expect(res.body).to.be.an("array");
  });

  test("processed bucket contains file", function() {
    expect(res.body).to.include("myFile.png");
  });
}
